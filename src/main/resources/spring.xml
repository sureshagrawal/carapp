<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

    <bean id="car" class="com.nsgacademy.Car">
        <property name="battery" ref="bat"/>
        <property name="engine" ref="peng"/>
<!--        <property name="tyre" ref="ty"/>-->

        <property name="tyres">
            <list>
                <ref bean="ty1"/>
                <ref bean="ty2"/>
                <ref bean="ty3"/>
                <ref bean="ty4"/>
            </list>
        </property>

<!--        <constructor-arg type="Engine" ref="peng"/>-->
<!--        <constructor-arg type="Battery" ref="bat"/>-->
<!--        <constructor-arg type="java.util.List">-->
<!--            <list>-->
<!--                <ref bean="ty1"/>-->
<!--                <ref bean="ty2"/>-->
<!--                <ref bean="ty3"/>-->
<!--                <ref bean="ty4"/>-->
<!--            </list>-->
<!--        </constructor-arg>-->

<!--        <constructor-arg index="1" ref="peng"/>-->
<!--        <constructor-arg index="0" ref="bat"/>-->
<!--        <constructor-arg index="2" ref="ty"/>-->

    </bean>

    <bean id="bat" class="com.nsgacademy.Battery"></bean>

<!--    <bean id="ty" class="com.nsgacademy.Tyre"></bean>-->
    <bean id="ty1" class="com.nsgacademy.Tyre"></bean>
    <bean id="ty2" class="com.nsgacademy.Tyre"></bean>
    <bean id="ty3" class="com.nsgacademy.Tyre"></bean>
    <bean id="ty4" class="com.nsgacademy.Tyre"></bean>


    <!--    <bean id="en" class="com.nsgacademy.Engine"></bean>-->

    <bean id="peng" class="com.nsgacademy.PetrolEngine">
        <property name="fuelPump" ref="fp"/>
<!--        <constructor-arg ref="fp"/>-->
    </bean>

    <bean id="deng" class="com.nsgacademy.DieselEngine">
        <property name="fuelPump" ref="fp"/>
<!--        <constructor-arg ref="fp"/>-->
    </bean>

    <bean id="fp" class="com.nsgacademy.FuelPump"></bean>

</beans>